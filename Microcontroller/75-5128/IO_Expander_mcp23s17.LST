 137          /* read port a and port b mcp23s17 io expander */
 138          char* read_porta_portb(void)
 139          {
 140   1         unsigned char port[2];
 141   1         _IO_CS0(0); // enable chip select 0
 142   1         write_mcp23s17(CONTROL_READ); // write command
 143   1         write_mcp23s17(GP_IO_A); // address GPIO A input REGISTER
